    <div id="schedule" class="card">No schedule</div>
    <div id="waitlist" class="card">Waitlist: none</div>
    <div id="unscheduled" class="card">Unscheduled: none</div>

    <div class="card">
      <h3 style="margin-top:0">Export</h3>
      <input id="weekLabel" placeholder="Week 31">
