<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Sam Scheduler Step 5</title>
<style>
body{margin:0;font-family:-apple-system;background:#0f1115;color:#fff}
.top{padding:14px;background:#111}
.tabs{display:flex;gap:8px;margin-top:10px}
.tab,.btn,.mini{padding:10px;border-radius:10px;border:none;background:#222;color:#fff;font-weight:bold;cursor:pointer}
.tab.active,.btn{background:#6366f1}
.container{padding:14px}
.card{background:#1a1d26;padding:12px;border-radius:12px;margin-top:12px}
.grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px}
.day{padding:8px;border-radius:8px;background:#222;text-align:center;cursor:pointer}
.day.active{background:#6366f1}
input,select,textarea{width:100%;padding:10px;border-radius:8px;border:none;margin-top:8px;box-sizing:border-box}
.row{display:flex;gap:8px;flex-wrap:wrap}
.small{font-size:12px;opacity:.75}
.weekTable{width:100%;border-collapse:separate;border-spacing:8px}
.weekTable td,.weekTable th{vertical-align:top}
.slotBox{background:#222;padding:8px;border-radius:10px;min-width:170px}
.pill{display:inline-block;background:#6366f1;padding:3px 8px;border-radius:999px;font-size:11px;margin-left:6px}
.summaryStat{display:inline-block;background:#222;padding:8px 10px;border-radius:10px;margin:4px 6px 0 0}
.notice{margin-top:10px;padding:10px;border-radius:10px;background:#222;display:none}
.notice.show{display:block}
.sessionItem{margin-bottom:8px;padding:8px;border-radius:8px;background:#191f30}
.locked{outline:2px solid #f59e0b}
.noteTag{display:inline-block;background:#334155;padding:2px 6px;border-radius:999px;font-size:10px;margin-left:6px}
.modalBg{position:fixed;inset:0;background:rgba(0,0,0,.6);display:none;align-items:flex-end;justify-content:center;padding:20px;z-index:1000}
.modalBg.show{display:flex}
.modalCard{width:min(700px,100%);background:#111827;border-radius:16px;padding:16px}
.moveBtn{display:block;width:100%;text-align:left;margin-top:8px;padding:10px;border:none;border-radius:10px;background:#1f2937;color:#fff}
@media(max-width:700px){.grid{grid-template-columns:repeat(4,1fr)}}
</style>
</head>
<body>

<div class="top">
  <h2 style="margin:0">Sam’s Scheduler</h2>
  <div class="tabs">
    <button id="tabSchedule" class="tab active" onclick="showPage('schedule')">Schedule</button>
    <button id="tabStudents" class="tab" onclick="showPage('students')">Students</button>
    <button id="tabSettings" class="tab" onclick="showPage('settings')">Settings</button>
  </div>
</div>

<div class="container">

  <div id="notice" class="notice"></div>

  <div id="schedulePage">
    <div class="row">
      <button class="btn" onclick="build()">Auto Build</button>
      <button class="tab" onclick="reoptimize()">Re-optimize</button>
      <button class="tab" onclick="clearSchedule()">Clear Schedule</button>
      <button class="tab" onclick="buildExport()">Build Export</button>
    </div>

    <div id="summary" class="card">No schedule yet</div>
    <div id="schedule" class="card">No schedule</div>
    <div id="waitlist" class="card">Waitlist: none</div>
    <div id="unscheduled" class="card">Unscheduled: none</div>

    <div class="card">
      <h3 style="margin-top:0">Export</h3>
      <input id="weekLabel" placeholder="Week 31">
      <textarea id="exportBox" placeholder="Weekly export will appear here"></textarea>
    </div>
  </div>

  <div id="studentsPage" style="display:none">

    <div class="card">
      <h3 style="margin-top:0">Add Student</h3>
      <input id="name" placeholder="Student name">
      <div class="row">
        <button class="btn" onclick="addStudent()">Add Student</button>
      </div>
    </div>

    <div id="students" class="card">No students yet</div>

    <div class="card">
      <h3 style="margin-top:0">Selected Student Settings</h3>
      <div id="selectedLabel">Select a student first</div>

      <label>Group packages</label>
      <select id="pkgGroup">
        <option value="0">0</option><option value="1">1</option><option value="2">2</option><option value="3">3</option>
      </select>

      <label>Advanced packages</label>
      <select id="pkgAdvanced">
        <option value="0">0</option><option value="1">1</option><option value="2">2</option><option value="3">3</option>
      </select>

      <label>Private packages</label>
      <select id="pkgPrivate">
        <option value="0">0</option><option value="1">1</option><option value="2">2</option><option value="3">3</option>
      </select>

      <label>Online packages</label>
      <select id="pkgOnline">
        <option value="0">0</option><option value="1">1</option><option value="2">2</option><option value="3">3</option>
      </select>

      <label>Max sessions per day</label>
      <select id="maxPerDay">
        <option value="1">1</option><option value="2">2</option><option value="3">3</option>
      </select>

      <div class="row" style="margin-top:10px">
        <button class="btn" onclick="saveStudentSettings()">Save Student Settings</button>
      </div>
    </div>

    <div class="card">
      <h3 style="margin-top:0">Edit Availability</h3>

      <label>Type</label>
      <select id="availType" onchange="renderDays()">
        <option value="Group">Group</option>
        <option value="Advanced">Advanced</option>
        <option value="Private">Private</option>
        <option value="Online">Online</option>
      </select>

      <label>Slot</label>
      <select id="availSlot" onchange="renderDays()">
        <option value="Morning">Morning</option>
        <option value="Afternoon">Afternoon</option>
        <option value="Evening">Evening</option>
        <option value="Late Night">Late Night</option>
      </select>

      <div class="row" style="margin-top:10px">
        <button class="mini" onclick="bulkWeekdays()">Weekdays</button>
        <button class="mini" onclick="bulkAllDays()">All Days</button>
        <button class="mini" onclick="clearCurrentTypeSlot()">Clear Current Type/Slot</button>
        <button class="mini" onclick="copyAvailability('Group','Advanced')">Copy Group → Advanced</button>
        <button class="mini" onclick="copyAvailability('Group','Private')">Copy Group → Private</button>
        <button class="mini" onclick="copyAvailability('Group','Online')">Copy Group → Online</button>
      </div>

      <div style="margin-top:10px" id="days" class="grid"></div>

      <div class="row" style="margin-top:10px">
        <button class="btn" onclick="saveAvailability()">Save Availability</button>
      </div>
    </div>

    <div id="selectedSummary" class="card">No student selected</div>

  </div>

  <div id="settingsPage" style="display:none">
    <div class="card">
      <h3 style="margin-top:0">Session Capacities</h3>
      <label>Group capacity</label>
      <select id="groupCap" onchange="saveCapSettings()">
        <option value="2">2</option><option value="3">3</option><option value="4">4</option><option value="5">5</option><option value="6">6</option>
      </select>

      <label>Advanced capacity</label>
      <select id="advancedCap" onchange="saveCapSettings()">
        <option value="2">2</option><option value="3">3</option><option value="4">4</option>
      </select>

      <label>Online capacity</label>
      <select id="onlineCap" onchange="saveCapSettings()">
        <option value="2">2</option><option value="3">3</option><option value="4">4</option>
      </select>
    </div>

    <div class="card">
      <h3 style="margin-top:0">Default Times</h3>
      <label>Morning</label><input id="timeMorning" onchange="saveTimeSettings()">
      <label>Afternoon</label><input id="timeAfternoon" onchange="saveTimeSettings()">
      <label>Evening</label><input id="timeEvening" onchange="saveTimeSettings()">
      <label>Late Night</label><input id="timeLateNight" onchange="saveTimeSettings()">
    </div>

    <div class="card">
      <h3 style="margin-top:0">App State</h3>
      <div class="row">
        <button class="tab" onclick="exportState()">Export App State</button>
        <button class="tab" onclick="importState()">Import App State</button>
      </div>
      <textarea id="stateBox" placeholder="Full app JSON"></textarea>
    </div>
  </div>

</div>

<div id="moveModal" class="modalBg">
  <div class="modalCard">
    <h3 id="moveTitle" style="margin-top:0">Move Session</h3>
    <div id="moveInfo" class="small"></div>
    <label>Session note</label>
    <textarea id="moveNote"></textarea>
    <div class="row" style="margin-top:10px">
      <button class="mini" onclick="toggleLockSelected()">Lock / Unlock</button>
      <button class="mini" onclick="removeSelectedSession()">Remove Session</button>
      <button class="mini" onclick="closeMoveModal()">Close</button>
    </div>
    <div id="moveTargets" style="margin-top:12px"></div>
  </div>
</div>

<script>
const DAYS = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"];
const SLOTS = ["Morning","Afternoon","Evening","Late Night"];
const TYPE_ORDER = {Private:4, Online:3, Advanced:2, Group:1};
const STORAGE_KEY = "sam_scheduler_step5";

let students = [];
let selected = null;
let schedule = [];
let waitlist = [];
let unscheduled = [];
let selectedSessionId = null;
let settings = {
  groupCap: 4,
  advancedCap: 4,
  onlineCap: 4,
  times: {
    Morning: "10:00 AM",
    Afternoon: "2:00 PM",
    Evening: "6:30 PM",
    "Late Night": "9:30 PM"
  }
};

function notice(msg){
  const el = document.getElementById("notice");
  if(!msg){ el.classList.remove("show"); el.textContent = ""; return; }
  el.textContent = msg;
  el.classList.add("show");
}

function saveApp(){
  localStorage.setItem(STORAGE_KEY, JSON.stringify({
    students, selected, schedule, waitlist, unscheduled, settings
  }));
}

function loadApp(){
  const raw = localStorage.getItem(STORAGE_KEY);
  if(!raw) return;
  try{
    const parsed = JSON.parse(raw);
    students = parsed.students || [];
    selected = parsed.selected || null;
    schedule = parsed.schedule || [];
    waitlist = parsed.waitlist || [];
    unscheduled = parsed.unscheduled || [];
    settings = parsed.settings || settings;
  }catch(e){}
}

function showPage(page){
  document.getElementById("schedulePage").style.display = page==="schedule" ? "block" : "none";
  document.getElementById("studentsPage").style.display = page==="students" ? "block" : "none";
  document.getElementById("settingsPage").style.display = page==="settings" ? "block" : "none";
  document.getElementById("tabSchedule").classList.toggle("active", page==="schedule");
  document.getElementById("tabStudents").classList.toggle("active", page==="students");
  document.getElementById("tabSettings").classList.toggle("active", page==="settings");
}

function uid(){
  return Date.now().toString() + Math.random().toString(36).slice(2,7);
}

function escapeHtml(text){
  return String(text).replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;");
}

function getCap(type){
  if(type==="Group") return settings.groupCap;
  if(type==="Advanced") return settings.advancedCap;
  if(type==="Online") return settings.onlineCap;
  return 1;
}

function sessionNote(session){
  return session.note ? session.note : "";
}

function addStudent(){
  const name = document.getElementById("name").value.trim();
  if(!name) return;
  students.push({
    id: uid(),
    name,
    packages: { Group:1, Advanced:0, Private:0, Online:0 },
    maxPerDay: 1,
    availability: []
  });
  document.getElementById("name").value = "";
  renderStudents();
  saveApp();
}

function renderStudents(){
  const box = document.getElementById("students");
  if(students.length===0){
    box.innerHTML = "No students yet";
    return;
  }

  box.innerHTML = students.map(s => `
    <div class="card" style="margin-top:8px;cursor:pointer;border:${selected===s.id?'2px solid #6366f1':'none'}" onclick="selectStudent('${s.id}')">
      <b>${escapeHtml(s.name)}</b><br>
      <span class="small">
        G:${s.packages.Group} A:${s.packages.Advanced} P:${s.packages.Private} O:${s.packages.Online}
        • Max/day ${s.maxPerDay}
        • ${s.availability.length} availability entries
      </span>
    </div>
  `).join("");
}

function getSelectedStudent(){
  return students.find(s => s.id === selected) || null;
}

function selectStudent(id){
  selected = id;
  renderStudents();
  loadSelectedSettings();
  renderSelected();
  renderDays();
  saveApp();
}

function loadSelectedSettings(){
  const s = getSelectedStudent();
  if(!s) return;
  document.getElementById("pkgGroup").value = s.packages.Group;
  document.getElementById("pkgAdvanced").value = s.packages.Advanced;
  document.getElementById("pkgPrivate").value = s.packages.Private;
  document.getElementById("pkgOnline").value = s.packages.Online;
  document.getElementById("maxPerDay").value = s.maxPerDay;
}

function saveStudentSettings(){
  const s = getSelectedStudent();
  if(!s) return alert("Select a student first");
  s.packages.Group = Number(document.getElementById("pkgGroup").value);
  s.packages.Advanced = Number(document.getElementById("pkgAdvanced").value);
  s.packages.Private = Number(document.getElementById("pkgPrivate").value);
  s.packages.Online = Number(document.getElementById("pkgOnline").value);
  s.maxPerDay = Number(document.getElementById("maxPerDay").value);
  renderStudents();
  renderSelected();
  saveApp();
  notice("Student settings saved.");
}

function renderSelected(){
  const s = getSelectedStudent();
  document.getElementById("selectedLabel").textContent = s ? `Editing: ${s.name}` : "Select a student first";

  const box = document.getElementById("selectedSummary");
  if(!s){
    box.textContent = "No student selected";
    return;
  }

  if(s.availability.length===0){
    box.innerHTML = `<b>${escapeHtml(s.name)}</b><br><span class="small">No availability saved yet</span>`;
    return;
  }

  const rows = [...s.availability].sort((a,b) => {
    if(a.type !== b.type) return a.type.localeCompare(b.type);
    if(a.slot !== b.slot) return SLOTS.indexOf(a.slot) - SLOTS.indexOf(b.slot);
    return DAYS.indexOf(a.day) - DAYS.indexOf(b.day);
  });

  box.innerHTML = `
    <b>${escapeHtml(s.name)}</b><br>
    <span class="small">G:${s.packages.Group} A:${s.packages.Advanced} P:${s.packages.Private} O:${s.packages.Online} • Max/day ${s.maxPerDay}</span>
    ${rows.map(a => `<div style="margin-top:6px">${a.type} — ${a.slot} — ${a.day}</div>`).join("")}
  `;
}

function currentType(){ return document.getElementById("availType").value; }
function currentSlot(){ return document.getElementById("availSlot").value; }

function hasAvailability(student, type, slot, day){
  return student.availability.some(a => a.type===type && a.slot===slot && a.day===day);
}

function renderDays(){
  const s = getSelectedStudent();
  if(!s){
    document.getElementById("days").innerHTML = "Select a student first";
    return;
  }
  const type = currentType();
  const slot = currentSlot();

  document.getElementById("days").innerHTML = DAYS.map(day => {
    const active = hasAvailability(s, type, slot, day);
    return `<div class="day ${active?'active':''}" onclick="toggleDay('${day}')">${day}</div>`;
  }).join("");
}

function toggleDay(day){
  const s = getSelectedStudent();
  if(!s) return;
  const type = currentType();
  const slot = currentSlot();
  const idx = s.availability.findIndex(a => a.type===type && a.slot===slot && a.day===day);
  if(idx >= 0) s.availability.splice(idx, 1);
  else s.availability.push({ type, slot, day });
  renderDays();
  renderSelected();
  renderStudents();
}

function bulkWeekdays(){
  const s = getSelectedStudent();
  if(!s) return;
  const type = currentType();
  const slot = currentSlot();
  ["Mon","Tue","Wed","Thu","Fri"].forEach(day => {
    if(!hasAvailability(s, type, slot, day)) s.availability.push({ type, slot, day });
  });
  renderDays(); renderSelected(); renderStudents();
}

function bulkAllDays(){
  const s = getSelectedStudent();
  if(!s) return;
  const type = currentType();
  const slot = currentSlot();
  DAYS.forEach(day => {
    if(!hasAvailability(s, type, slot, day)) s.availability.push({ type, slot, day });
  });
  renderDays(); renderSelected(); renderStudents();
}

function clearCurrentTypeSlot(){
  const s = getSelectedStudent();
  if(!s) return;
  const type = currentType();
  const slot = currentSlot();
  s.availability = s.availability.filter(a => !(a.type===type && a.slot===slot));
  renderDays(); renderSelected(); renderStudents();
}

function copyAvailability(fromType, toType){
  const s = getSelectedStudent();
  if(!s) return alert("Select a student first");
  const source = s.availability.filter(a => a.type===fromType);
  s.availability = s.availability.filter(a => a.type!==toType);
  source.forEach(a => s.availability.push({ type: toType, slot: a.slot, day: a.day }));
  renderDays(); renderSelected(); renderStudents(); saveApp();
  notice(`Copied ${fromType} availability to ${toType}.`);
}

function saveAvailability(){
  const s = getSelectedStudent();
  if(!s) return alert("Select a student first");
  saveApp();
  notice("Availability saved.");
}

function preferenceOrder(type){
  if(type==="Online") return ["Late Night","Evening","Afternoon","Morning"];
  if(type==="Private") return ["Morning","Afternoon","Evening","Late Night"];
  return ["Afternoon","Evening","Morning","Late Night"];
}

function slotScore(type, day, slot, built){
  let score = 0;
  const pref = preferenceOrder(type);
  score += (4 - pref.indexOf(slot)) * 10;

  const sameCount = built.filter(x => x.type===type && x.day===day && x.slot===slot).length;

  if(type==="Private"){
    if(sameCount===0) score += 20;
    else score -= 1000;
    return score;
  }

  if(sameCount===0) score += 2;
  if(sameCount===1) score += 30;
  if(sameCount===2) score += 20;
  if(sameCount===3) score += 12;
  if(sameCount>=getCap(type)) score -= 1000;

  return score;
}

function sameDayCount(studentId, day, built){
  return built.filter(x => x.studentId===studentId && x.day===day).length;
}

function canPlace(student, option, built){
  const sameStudentSameSlot = built.some(x => x.studentId===student.id && x.day===option.day && x.slot===option.slot);
  if(sameStudentSameSlot) return false;
  if(sameDayCount(student.id, option.day, built) >= student.maxPerDay) return false;

  const sameSessionCount = built.filter(x => x.type===option.type && x.day===option.day && x.slot===option.slot).length;
  if(option.type==="Private"){
    if(sameSessionCount >= 1) return false;
  } else {
    if(sameSessionCount >= getCap(option.type)) return false;
  }
  return true;
}

function buildRequests(){
  const requests = [];
  students.forEach(s => {
    const grouped = {};
    s.availability.forEach(a => {
      if(!grouped[a.type]) grouped[a.type] = [];
      grouped[a.type].push(a);
    });

    Object.keys(grouped).forEach(type => {
      const packageCount = Number(s.packages[type] || 0);
      for(let i=0;i<packageCount;i++){
        requests.push({
          id: uid(),
          studentId: s.id,
          studentName: s.name,
          type,
          options: grouped[type],
          requestIndex: i + 1
        });
      }
    });
  });

  requests.sort((a,b) => TYPE_ORDER[b.type] - TYPE_ORDER[a.type]);
  return requests;
}

function tryMoveSolo(type){
  let moved = false;
  const groups = {};
  schedule.filter(x => x.type===type).forEach(s => {
    const key = `${s.day}|${s.slot}`;
    if(!groups[key]) groups[key] = [];
    groups[key].push(s);
  });

  Object.keys(groups).forEach(key => {
    const group = groups[key];
    if(group.length !== 1) return;
    const solo = group[0];
    if(solo.locked) return;
    const student = students.find(s => s.id===solo.studentId);
    if(!student) return;

    let bestTarget = null;
    let bestScore = -999;
    for(const option of student.availability){
      if(option.type !== type) continue;
      if(option.day===solo.day && option.slot===solo.slot) continue;
      if(sameDayCount(student.id, option.day, schedule.filter(x => x.id!==solo.id)) >= student.maxPerDay) continue;

      const targetCount = schedule.filter(x => x.type===type && x.day===option.day && x.slot===option.slot).length;
      if(targetCount < 1) continue;
      if(targetCount >= getCap(type)) continue;

      const score = slotScore(type, option.day, option.slot, schedule);
      if(score > bestScore){
        bestScore = score;
        bestTarget = option;
      }
    }

    if(bestTarget){
      solo.day = bestTarget.day;
      solo.slot = bestTarget.slot;
      moved = true;
    }
  });
  return moved;
}

function waitlistRemainingSolos(type){
  const groups = {};
  schedule.filter(x => x.type===type).forEach(s => {
    const key = `${s.day}|${s.slot}`;
    if(!groups[key]) groups[key] = [];
    groups[key].push(s);
  });

  Object.keys(groups).forEach(key => {
    const group = groups[key];
    if(group.length !== 1) return;
    const solo = group[0];
    if(solo.locked) return;
    schedule = schedule.filter(x => x.id !== solo.id);
    waitlist.push({
      studentId: solo.studentId,
      studentName: solo.studentName,
      type: solo.type,
      reason: "Could not form 2+ cohort"
    });
  });
}

function build(){
  schedule = [];
  waitlist = [];
  unscheduled = [];

  const requests = buildRequests();

  requests.forEach(req => {
    const student = students.find(s => s.id===req.studentId);
    if(!student) return;

    const viable = req.options.filter(opt => canPlace(student, opt, schedule));
    if(viable.length===0){
      unscheduled.push({
        studentId: req.studentId,
        studentName: req.studentName,
        type: req.type,
        reason: "No viable placement"
      });
      return;
    }

    viable.sort((a,b) => slotScore(req.type, b.day, b.slot, schedule) - slotScore(req.type, a.day, a.slot, schedule));
    const best = viable[0];

    schedule.push({
      id: req.id,
      studentId: req.studentId,
      studentName: req.studentName,
      type: req.type,
      day: best.day,
      slot: best.slot,
      requestIndex: req.requestIndex,
      locked: false,
      note: ""
    });
  });

  tryMoveSolo("Group");
  tryMoveSolo("Advanced");
  tryMoveSolo("Online");
  waitlistRemainingSolos("Group");
  waitlistRemainingSolos("Advanced");
  waitlistRemainingSolos("Online");

  renderSchedule();
  saveApp();
  notice("Auto-build complete.");
}

function reoptimize(){
  const locked = schedule.filter(x => x.locked);
  const unlocked = schedule.filter(x => !x.locked);
  const lockIds = new Set(locked.map(x => x.id));

  const oldNotes = {};
  schedule.forEach(s => oldNotes[s.id] = { note: s.note || "", locked: !!s.locked });

  schedule = [...locked];
  waitlist = [];
  unscheduled = [];

  const requests = buildRequests().filter(req => !lockIds.has(req.id));

  requests.forEach(req => {
    const student = students.find(s => s.id===req.studentId);
    if(!student) return;

    const viable = req.options.filter(opt => canPlace(student, opt, schedule));
    if(viable.length===0){
      unscheduled.push({
        studentId: req.studentId,
        studentName: req.studentName,
        type: req.type,
        reason: "No viable placement"
      });
      return;
    }

    viable.sort((a,b) => slotScore(req.type, b.day, b.slot, schedule) - slotScore(req.type, a.day, a.slot, schedule));
    const best = viable[0];

    schedule.push({
      id: req.id,
      studentId: req.studentId,
      studentName: req.studentName,
      type: req.type,
      day: best.day,
      slot: best.slot,
      requestIndex: req.requestIndex,
      locked: false,
      note: oldNotes[req.id]?.note || ""
    });
  });

  tryMoveSolo("Group");
  tryMoveSolo("Advanced");
  tryMoveSolo("Online");
  waitlistRemainingSolos("Group");
  waitlistRemainingSolos("Advanced");
  waitlistRemainingSolos("Online");

  renderSchedule();
  saveApp();
  notice("Re-optimized.");
}

function renderSchedule(){
  renderSummary();

  const map = {};
  DAYS.forEach(day => {
    map[day] = {};
    SLOTS.forEach(slot => map[day][slot] = []);
  });

  schedule.forEach(s => map[s.day][s.slot].push(s));

  document.getElementById("schedule").innerHTML = `
    <table class="weekTable">
      <thead>
        <tr>
          <th></th>
          ${DAYS.map(d => `<th>${d}</th>`).join("")}
        </tr>
      </thead>
      <tbody>
        ${SLOTS.map(slot => `
          <tr>
            <th>${slot}</th>
            ${DAYS.map(day => `
              <td>
                <div class="slotBox">
                  ${
                    map[day][slot].length
                      ? map[day][slot].map(x => `
                          <div class="sessionItem ${x.locked ? "locked":""}" onclick="openMoveModal('${x.id}')">
                            <b>${x.type}</b><span class="pill">${x.studentName}${x.requestIndex>1 ? " #" + x.requestIndex : ""}</span>
                            ${x.note ? `<span class="noteTag">note</span>` : ""}
                            <div class="small">${settings.times[x.slot] || ""}${x.locked ? " • locked" : ""}</div>
                          </div>
                        `).join("")
                      : `<div class="small">—</div>`
                  }
                </div>
              </td>
            `).join("")}
          </tr>
        `).join("")}
      </tbody>
    </table>
  `;

  if(waitlist.length===0){
    document.getElementById("waitlist").innerHTML = "Waitlist: none";
  } else {
    document.getElementById("waitlist").innerHTML = `
      <b>Waitlist</b>
      ${waitlist.map(w => `
        <div style="margin-top:8px">
          <b>${escapeHtml(w.studentName)}</b> — ${escapeHtml(w.type)}<br>
          <span class="small">${escapeHtml(w.reason)}</span>
        </div>
      `).join("")}
    `;
  }

  if(unscheduled.length===0){
    document.getElementById("unscheduled").innerHTML = "Unscheduled: none";
  } else {
    document.getElementById("unscheduled").innerHTML = `
      <b>Unscheduled</b>
      ${unscheduled.map(u => `
        <div style="margin-top:8px">
          <b>${escapeHtml(u.studentName)}</b> — ${escapeHtml(u.type)}<br>
          <span class="small">${escapeHtml(u.reason)}</span>
        </div>
      `).join("")}
    `;
  }
}

function renderSummary(){
  const counts = {
    Group: schedule.filter(x => x.type==="Group").length,
    Advanced: schedule.filter(x => x.type==="Advanced").length,
    Private: schedule.filter(x => x.type==="Private").length,
    Online: schedule.filter(x => x.type==="Online").length
  };

  const cohorts = {};
  schedule.forEach(s => {
    const key = `${s.type}|${s.day}|${s.slot}`;
    if(!cohorts[key]) cohorts[key] = 0;
    cohorts[key]++;
  });

  document.getElementById("summary").innerHTML = `
    <div class="summaryStat">Total scheduled: ${schedule.length}</div>
    <div class="summaryStat">Group: ${counts.Group}</div>
    <div class="summaryStat">Advanced: ${counts.Advanced}</div>
    <div class="summaryStat">Private: ${counts.Private}</div>
    <div class="summaryStat">Online: ${counts.Online}</div>
    <div class="summaryStat">Sessions: ${Object.keys(cohorts).length}</div>
  `;
}

function clearSchedule(){
  schedule = [];
  waitlist = [];
  unscheduled = [];
  renderSchedule();
  saveApp();
}

function buildExport(){
  const label = document.getElementById("weekLabel").value.trim() || "Weekly Schedule";
  const lines = [label, ""];

  DAYS.forEach(day => {
    lines.push(day);

    const items = schedule
      .filter(x => x.day===day)
      .sort((a,b) => SLOTS.indexOf(a.slot) - SLOTS.indexOf(b.slot));

    if(items.length===0){
      lines.push("OFF", "");
      return;
    }

    items.forEach(x => {
      const time = settings.times[x.slot] || "";
      const note = x.note ? ` [${x.note}]` : "";
      lines.push(`${x.slot}${time ? " (" + time + ")" : ""} — ${x.type} — ${x.studentName}${x.requestIndex>1 ? " #" + x.requestIndex : ""}${note}`);
    });
    lines.push("");
  });

  document.getElementById("exportBox").value = lines.join("\n").trim();
}

function saveCapSettings(){
  settings.groupCap = Number(document.getElementById("groupCap").value);
  settings.advancedCap = Number(document.getElementById("advancedCap").value);
  settings.onlineCap = Number(document.getElementById("onlineCap").value);
  saveApp();
  notice("Capacity settings saved.");
}

function saveTimeSettings(){
  settings.times.Morning = document.getElementById("timeMorning").value;
  settings.times.Afternoon = document.getElementById("timeAfternoon").value;
  settings.times.Evening = document.getElementById("timeEvening").value;
  settings.times["Late Night"] = document.getElementById("timeLateNight").value;
  saveApp();
  notice("Default times saved.");
}

function exportState(){
  document.getElementById("stateBox").value = JSON.stringify({
    students, selected, schedule, waitlist, unscheduled, settings
  }, null, 2);
  notice("App state exported.");
}

function importState(){
  const raw = document.getElementById("stateBox").value.trim();
  if(!raw) return alert("Paste JSON first.");

  try{
    const parsed = JSON.parse(raw);
    students = parsed.students || [];
    selected = parsed.selected || null;
    schedule = parsed.schedule || [];
    waitlist = parsed.waitlist || [];
    unscheduled = parsed.unscheduled || [];
    settings = parsed.settings || settings;
    init();
    saveApp();
    notice("App state imported.");
  }catch(e){
    alert("Invalid JSON");
  }
}

function openMoveModal(sessionId){
  selectedSessionId = sessionId;
  const s = schedule.find(x => x.id===sessionId);
  if(!s) return;

  document.getElementById("moveModal").classList.add("show");
  document.getElementById("moveTitle").textContent = `Move ${s.studentName}`;
  document.getElementById("moveInfo").textContent = `${s.type} — ${s.day} ${s.slot}`;
  document.getElementById("moveNote").value = s.note || "";

  const student = students.find(st => st.id===s.studentId);
  if(!student) return;

  const targets = student.availability
    .filter(a => a.type===s.type)
    .sort((a,b) => {
      if(a.day!==b.day) return DAYS.indexOf(a.day)-DAYS.indexOf(b.day);
      return SLOTS.indexOf(a.slot)-SLOTS.indexOf(b.slot);
    });

  document.getElementById("moveTargets").innerHTML = targets.map(t => `
    <button class="moveBtn" onclick="moveSelectedTo('${t.day}','${t.slot}')">
      ${t.day} — ${t.slot}
    </button>
  `).join("");
}

function closeMoveModal(){
  document.getElementById("moveModal").classList.remove("show");
  selectedSessionId = null;
}

function moveSelectedTo(day, slot){
  const s = schedule.find(x => x.id===selectedSessionId);
  if(!s) return;

  const student = students.find(st => st.id===s.studentId);
  if(!student) return;

  const otherDayCount = schedule.filter(x => x.id!==s.id && x.studentId===s.studentId && x.day===day).length;
  if(otherDayCount >= student.maxPerDay){
    alert("That would exceed max sessions per day.");
    return;
  }

  const sameSessionCount = schedule.filter(x => x.id!==s.id && x.type===s.type && x.day===day && x.slot===slot).length;
  if(s.type==="Private" && sameSessionCount >= 1){
    alert("Private slot already taken.");
    return;
  }
  if(s.type!=="Private" && sameSessionCount >= getCap(s.type)){
    alert("That session is already full.");
    return;
  }

  s.day = day;
  s.slot = slot;
  s.note = document.getElementById("moveNote").value.trim();
  renderSchedule();
  saveApp();
  closeMoveModal();
  notice("Session moved.");
}

function toggleLockSelected(){
  const s = schedule.find(x => x.id===selectedSessionId);
  if(!s) return;
  s.locked = !s.locked;
  s.note = document.getElementById("moveNote").value.trim();
  renderSchedule();
  saveApp();
  notice(s.locked ? "Session locked." : "Session unlocked.");
}

function removeSelectedSession(){
  const s = schedule.find(x => x.id===selectedSessionId);
  if(!s) return;
  schedule = schedule.filter(x => x.id!==s.id);
  renderSchedule();
  saveApp();
  closeMoveModal();
  notice("Session removed.");
}

document.getElementById("moveNote").addEventListener("input", () => {
  const s = schedule.find(x => x.id===selectedSessionId);
  if(!s) return;
  s.note = document.getElementById("moveNote").value.trim();
  saveApp();
});

function init(){
  loadApp();
  document.getElementById("groupCap").value = settings.groupCap;
  document.getElementById("advancedCap").value = settings.advancedCap;
  document.getElementById("onlineCap").value = settings.onlineCap;
  document.getElementById("timeMorning").value = settings.times.Morning || "";
  document.getElementById("timeAfternoon").value = settings.times.Afternoon || "";
  document.getElementById("timeEvening").value = settings.times.Evening || "";
  document.getElementById("timeLateNight").value = settings.times["Late Night"] || "";
  renderStudents();
  renderSchedule();

  if(selected){
    loadSelectedSettings();
    renderSelected();
    renderDays();
  }
}

init();
</script>

