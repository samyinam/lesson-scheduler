</div>

<div id="moveModal" class="modalBg">
  <div class="modalCard">
    <h3 id="moveTitle" style="margin-top:0">Move Session</h3>
    <div id="moveInfo" class="small"></div>
    <label>Session note</label>
    <textarea id="moveNote"></textarea>
    <div class="row" style="margin-top:10px">
      <button class="mini" onclick="toggleLockSelected()">Lock / Unlock</button>
      <button class="mini" onclick="removeSelectedSession()">Remove Session</button>
      <button class="mini" onclick="closeMoveModal()">Close</button>
    </div>
    <div id="moveTargets" style="margin-top:12px"></div>
  </div>
</div>
<script>

// ===============================
// STEP 6 OPTIMIZED ENGINE
// ===============================

function build(){

  schedule = [];
  waitlist = [];
  unscheduled = [];

  const requests = buildRequests();

  // STEP 1: BUILD ADVANCED FIRST (PAIR PRIORITY)
  buildPairs("Advanced");

  // STEP 2: BUILD GROUP (EVENING PRIORITY)
  buildPairs("Group");

  // STEP 3: PLACE REMAINING REQUESTS
  placeRemaining(requests);

  // STEP 4: RESCUE PASS (VERY IMPORTANT)
  rescuePass();

  renderSchedule();
  saveApp();
  notice("Step 6 optimized build complete");
}


// ===============================
// PAIR BUILDER
// ===============================

function buildPairs(type){

  const grouped = {};

  students.forEach(s=>{
    s.availability
      .filter(a=>a.type===type)
      .forEach(a=>{
        const key = `${a.day}|${a.slot}`;
        if(!grouped[key]) grouped[key]=[];
        grouped[key].push(s);
      });
  });

  Object.keys(grouped).forEach(key=>{
    const [day,slot] = key.split("|");

    let candidates = grouped[key]
      .filter(s => canUseStudentForType(s,type,day,slot))
      .sort((a,b)=> priorityScore(type,b.slot)-priorityScore(type,a.slot));

    while(candidates.length >= 2){

      const s1 = candidates.shift();
      const s2 = candidates.shift();

      schedule.push(makeSession(s1,type,day,slot));
      schedule.push(makeSession(s2,type,day,slot));
    }
  });
}


// ===============================
// REMAINING PLACEMENT
// ===============================

function placeRemaining(requests){

  requests.forEach(req=>{
    if(schedule.some(s=>s.studentId===req.studentId && s.type===req.type)) return;

    const student = students.find(s=>s.id===req.studentId);

    const viable = req.options.filter(opt =>
      canPlace(student,opt,schedule)
    );

    if(viable.length===0){
      unscheduled.push(req);
      return;
    }

    viable.sort((a,b)=>
      slotScore(req.type,b.day,b.slot,schedule)
      - slotScore(req.type,a.day,a.slot,schedule)
    );

    const best = viable[0];

    schedule.push(makeSession(student,req.type,best.day,best.slot));
  });
}


// ===============================
// RESCUE PASS (CRITICAL)
// ===============================

function rescuePass(){

  let changed = true;

  while(changed){
    changed = false;

    const solos = findSoloSessions();

    solos.forEach(solo=>{

      const student = students.find(x=>x.id===solo.studentId);
      if(!student) return;

      for(const opt of student.availability){

        if(opt.type !== solo.type) continue;

        const groupCount = countSession(opt.type,opt.day,opt.slot);

        if(groupCount === 1){

          // MOVE SOLO → PAIR
          solo.day = opt.day;
          solo.slot = opt.slot;
          changed = true;
          return;
        }
      }
    });
  }
}


// ===============================
// HELPERS
// ===============================

function makeSession(student,type,day,slot){
  return {
    id: uid(),
    studentId: student.id,
    studentName: student.name,
    type,
    day,
    slot,
    locked:false,
    note:""
  };
}

function canUseStudentForType(student,type,day,slot){

  if(!student.packages[type]) return false;

  const used = schedule.filter(s=>
    s.studentId===student.id &&
    s.type===type
  ).length;

  if(used >= student.packages[type]) return false;

  return canPlace(student,{type,day,slot},schedule);
}

function countSession(type,day,slot){
  return schedule.filter(s=>s.type===type && s.day===day && s.slot===slot).length;
}

function findSoloSessions(){

  const map = {};

  schedule.forEach(s=>{
    const key = `${s.type}|${s.day}|${s.slot}`;
    if(!map[key]) map[key]=[];
    map[key].push(s);
  });

  return Object.values(map)
    .filter(group=>group.length===1)
    .map(group=>group[0]);
}


// ===============================
// SCORING (UPDATED)
// ===============================

function priorityScore(type,slot){

  if(type==="Group"){
    if(slot==="Evening") return 100;
    if(slot==="Afternoon") return 40;
    return 0;
  }

  if(type==="Advanced"){
    if(slot==="Afternoon") return 90;
    if(slot==="Evening") return 80;
    return 0;
  }

  if(type==="Online"){
    if(slot==="Late Night") return 100;
  }

  return 0;
}

function slotScore(type,day,slot,built){

  let score = priorityScore(type,slot);

  const count = countSession(type,day,slot);

  // reward forming groups
  if(count===1) score += 50;
  if(count===2) score += 20;

  // penalize weak group times
  if(type==="Group" && slot!=="Evening"){
    score -= 40;
  }

  return score;
}

</script>


